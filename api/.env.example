# IRONLOG API — copy to .env and adjust

# SQLite database file (default: ./db/ironlog.db)
# DB_PATH=./db/ironlog.db

# Listen address and port
# HOST=0.0.0.0
# PORT=3001

# When true, all /api/* calls require a valid login (Bearer token from POST /api/auth/login).
# Leave unset or false for legacy “Apply Role” header-only mode while you create passwords.
# IRONLOG_AUTH_REQUIRED=true

# Session lifetime for Bearer tokens (days)
# IRONLOG_SESSION_DAYS=14
